# Copy this file to local.properties. local.properties is ignored by Git.
# GitHub Rock uses OAuth App Device Flow, so only the public Client ID is needed in Android.
# The optional backend URL must point to a deployed HTTPS GitHub Rock Backend instance.
# Never add a client secret, access token, keystore, private key, or password here.
sdk.dir=/path/to/Android/Sdk
GITHUB_CLIENT_ID=Ov23lim8WhLjeUMqvuMj
GITHUB_ROCK_BACKEND_URL=https://api.example.com/
