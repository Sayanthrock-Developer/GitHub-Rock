{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitHub Rock",
  "version": "0.2.2",
  "identifier": "com.sayanthrock.githubrock.companion",
  "build": {
    "frontendDist": "../../site"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "GitHub Rock",
        "width": 1280,
        "height": 820,
        "minWidth": 360,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; connect-src 'self' https://api.github.com; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "GitHub Rock releases and project companion",
    "longDescription": "Installable companion for GitHub Rock releases, documentation, downloads, and project access.",
    "copyright": "Copyright © 2026 Sayanth Rock",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "hardenedRuntime": true
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "iOS": {
      "minimumSystemVersion": "15.0"
    }
  }
}
